  "keyFeatures": [
    "Luby Transform (LT) fountain codes implementation",
    "Robust Soliton Distribution for optimal degree sampling",
    "Error-resilient peeling decoder with authenticated verification",
    "Bitcoin blockchain integration via blk*.dat and bitcoinkernel",
    "Epoch-based encoding for scalable storage reduction",
    "Storage reduction experiments and simulations",
    "CLI tool for encode/decode operations",
    "Symbol normalization for variable-length blocks"
  ],
  "publicApiSurface": [
    "droplet::Droplet - Fountain-coded droplet structure",
    "droplet::Encoder - LT code encoder",
    "droplet::EpochParams - Epoch configuration parameters",
    "distribution::RobustSoliton - Robust Soliton Distribution",
    "distribution::DegreeDistribution - Degree distribution trait",
    "decoder::peeling_decode - Full payload recovery decoder",
    "decoder::peeling_check - Graph-only decoding simulation",
    "decoder::BlockVerifier - Pluggable block verification trait",
    "chain::BlkFileReader - Raw blk*.dat file reader",
    "chain::KernelBlockReader - bitcoinkernel-backed reader",
    "epoch::EpochConfig - User-facing epoch configuration",
    "epoch::compute_epoch_seed - Deterministic seed derivation",
    "epoch::auto_scale_droplets - Droplet count heuristics",
    "symbol::blocks_to_symbols - Block normalization",
    "symbol::symbols_to_blocks - Symbol reconstruction",
    "encode::write_droplet - Droplet serialization",
    "encode::read_droplet - Droplet deserialization",
    "xor::xor_blocks - Multi-block XOR operation",
    "experiment::storage_reduction_experiment - Simulation runner"
  ]
}
